# ─────────────────────────────────────────────────────────────────────────
# text-to-model — environment configuration
#
# Copy this file to ".env" and edit the values for YOUR setup:
#     cp .env.example .env
#
# The .env file is gitignored — never commit your real API key.
# Choose ONE of the two setups below (local Ollama, or a hosted API).
# ─────────────────────────────────────────────────────────────────────────


# ===== OPTION A: LOCAL OLLAMA (no API key, runs on your own machine) =========
# Install Ollama (https://ollama.com), then:  ollama pull <model>
# This is the default. Uncomment/edit as needed.

LLM_BACKEND=ollama
OLLAMA_HOST=http://localhost:11434

# The model you pulled. A capable default for this task is the 30B instruct
# model (needs ~20GB RAM/VRAM). On a smaller machine, an 8B model runs but
# produces lower-quality multi-step workflows.
#   ollama pull qwen3:30b-a3b-instruct-2507-q4_K_M     # capable, larger
#   ollama pull llama3.1:8b-instruct-q8_0              # fast, smaller, weaker
MODEL_NAME=qwen3:30b-a3b-instruct-2507-q4_K_M

# IMPORTANT: the system prompt is ~17K tokens. Many models default to a 4096
# context window and will reject every request. Keep this well above ~20000.
NUM_CTX=24576


# ===== OPTION B: HOSTED OpenAI-COMPATIBLE API (uses your own key) ============
# Works with any OpenAI-compatible provider (OpenAI, Together, Groq,
# OpenRouter, a hosted vLLM endpoint, etc.). To use this, set LLM_BACKEND=openai
# above (comment out the ollama line) and fill in the three values below.
#
# LLM_BACKEND=openai
# OPENAI_BASE_URL=https://api.openai.com/v1     # your provider's API root
# API_KEY=sk-your-secret-key-here               # NEVER commit this
# MODEL_NAME=gpt-4o-mini                         # a model your provider offers
#
# Note: this task needs a model that reliably returns valid JSON and follows
# multi-step instructions. Small/weak models will struggle regardless of host.


# ===== COMMON SETTINGS (apply to either option) =============================

# Lower = more deterministic. Keep low for reliable structured JSON output.
TEMPERATURE=0.1

# Max tokens for the model's response. Detailed workflows can exceed 4096.
MAX_TOKENS=6144

# Where the web server binds. 127.0.0.1 = local only (recommended).
# Use 0.0.0.0 ONLY if you understand the exposure (no auth is built in).
BIND_HOST=127.0.0.1
BIND_PORT=8080

# Query logging (captures each request/response to logs/queries.jsonl).
QUERY_LOG_ENABLED=1
QUERY_LOG_PATH=logs/queries.jsonl
